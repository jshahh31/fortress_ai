# ─── PROJECT SETTINGS ─────────────────────────────────────────
PROJECT_NAME="Fortress AI"
FRONTEND_URL="http://localhost:3000"

# ─── LLM / vLLM (MI300X Infrastructure) ──────────────────────
# Point this to your vLLM OpenAI-compatible endpoint
QWEN_API_BASE="http://localhost:8001/v1"
QWEN_MODEL="Qwen/Qwen3.6-27B"
LOCAL_API_KEY="your-vllm-api-key-here"
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ─── EXTERNAL SEARCH (Tavily) ────────────────────────────────
# Get your key at https://tavily.com/
TAVILY_API_KEY="tvly-your-api-key-here"

# ─── VECTOR DB (Qdrant) ──────────────────────────────────────
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="legal_documents"
EMBEDDING_MODEL="BAAI/bge-m3"

# ─── DATABASE (PostgreSQL / Prisma) ─────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fortress_ai"

# ─── CACHE & MESSAGING (Redis) ──────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ─── AUTHENTICATION (Clerk) ──────────────────────────────────
# Found in Clerk Dashboard -> API Keys
# Format: https://<your-app>.clerk.accounts.dev
CLERK_ISSUER="https://your-app.clerk.accounts.dev"
CLERK_JWKS_URL="https://your-app.clerk.accounts.dev/.well-known/jwks.json"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# ─── FILE UPLOADS ─────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=25

# ─── OPTIONAL: HUGGING FACE ──────────────────────────────────
# Required if you pull models from HF via the LLM service
HUGGING_FACE_HUB_TOKEN="hf_your_token_here"
